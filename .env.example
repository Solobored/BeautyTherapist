# =============================================================================
# SUPABASE CONFIGURATION
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DB_URL=postgresql://postgres:YOURPASSWORD@db.your-project.supabase.co:5432/postgres

# =============================================================================
# MERCADO PAGO CONFIGURATION
# =============================================================================
# Clave pública (frontend, opcional si solo usas Checkout Pro redirect)
NEXT_PUBLIC_MP_PUBLIC_KEY=TEST-PUBLIC-KEY
# Token de integración — obligatorio para crear preferencias y reembolsos
MERCADOPAGO_ACCESS_TOKEN=TEST-ACCESS-TOKEN
# Secreto para validar webhooks (panel MP → Webhooks)
MERCADOPAGO_WEBHOOK_SECRET=
MERCADOPAGO_INTEGRATOR_ID=
# true = usar sandbox_init_point y reglas laxas (localhost OK). false + token APP_USR = producción.
MERCADOPAGO_USE_SANDBOX=true

# URL pública ABSOLUTA del sitio (sin barra final). Crítico para Checkout Pro:
# - Producción (token APP_USR-… y MERCADOPAGO_USE_SANDBOX=false): usa https://tudominio.com
#   Si dejas http://localhost con credenciales LIVE, MP falla (invalid_auto_return) o no redirige bien.
# - Vercel: puedes dejar vacío y se usa VERCEL_URL automáticamente.
# - Webhooks: notification_url solo se envía si es https (producción).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional Mercado Pago test users (do not commit real creds)
MP_TEST_USER_EMAIL=
MP_TEST_USER_PASSWORD=

# =============================================================================
# RESEND CONFIGURATION (Email Service)
# =============================================================================
RESEND_API_KEY=re_test_key_here
# Dominio verificado en Resend, ej: Beauty Therapist <notificaciones@tudominio.com>
RESEND_FROM_EMAIL=

# =============================================================================
# CLOUDINARY CONFIGURATION (Image Upload Service)
# =============================================================================
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# =============================================================================
# CRON (Vercel / limpieza de pedidos cancelados antiguos)
# =============================================================================
# Secreto para GET /api/cron/purge-old-cancelled-orders — Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
# (Duplicado arriba si ya definiste NEXT_PUBLIC_APP_URL en la sección Mercado Pago)
